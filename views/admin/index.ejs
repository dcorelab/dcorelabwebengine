<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NeoAdmin • Dark</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"/>
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .glass { background: rgba(255,255,255,0.05); backdrop-filter: blur(12px); }
    .sidebar { transition: all 0.3s ease; }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-200 min-h-screen">

  <div class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <div id="sidebar" class="sidebar w-64 bg-zinc-900 border-r border-zinc-800 flex flex-col">
      <div class="p-6 border-b border-zinc-800">
        <h1 class="text-2xl font-bold tracking-tight flex items-center gap-2">
          <span class="w-8 h-8 bg-violet-600 rounded-xl flex items-center justify-center text-white font-black">N</span>
          NeoAdmin
        </h1>
      </div>

      <div class="flex-1 overflow-y-auto p-4">
        <nav class="space-y-1">
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium bg-zinc-800 rounded-2xl text-white">
            <i class="fa-solid fa-gauge-high"></i> Dashboard
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-800/70 rounded-2xl transition-colors">
            <i class="fa-solid fa-users"></i> Users
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-800/70 rounded-2xl transition-colors">
            <i class="fa-solid fa-chart-line"></i> Analytics
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-800/70 rounded-2xl transition-colors">
            <i class="fa-solid fa-box"></i> Products
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-800/70 rounded-2xl transition-colors">
            <i class="fa-solid fa-receipt"></i> Orders
          </a>
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-800/70 rounded-2xl transition-colors">
            <i class="fa-solid fa-gear"></i> Settings
          </a>
        </nav>
      </div>

      <div class="p-4 border-t border-zinc-800">
        <div class="flex items-center gap-3 px-4 py-3 bg-zinc-800 rounded-2xl">
          <div class="w-10 h-10 bg-zinc-700 rounded-full flex items-center justify-center">
            👨‍💼
          </div>
          <div>
            <p class="font-medium">Subhadip</p>
            <p class="text-xs text-zinc-400">Admin</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">

      <!-- Top Navbar -->
      <header class="bg-zinc-900 border-b border-zinc-800 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <button onclick="toggleSidebar()" class="lg:hidden text-2xl">
            <i class="fa-solid fa-bars"></i>
          </button>
          <div class="relative w-80">
            <input type="text" placeholder="Search anything..." 
                   class="w-full bg-zinc-800 border border-zinc-700 focus:border-violet-500 rounded-2xl py-3 px-5 pl-12 outline-none text-sm"/>
            <i class="fa-solid fa-magnifying-glass absolute left-5 top-3.5 text-zinc-400"></i>
          </div>
        </div>

        <div class="flex items-center gap-6">
          <button class="relative hover:scale-110 transition-transform">
            <i class="fa-solid fa-bell text-xl"></i>
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-rose-500 text-xs rounded-full flex items-center justify-center">3</span>
          </button>
          <button class="hover:scale-110 transition-transform">
            <i class="fa-solid fa-moon text-xl"></i>
          </button>
          <div class="flex items-center gap-3">
            <div class="text-right">
              <p class="text-sm font-medium">Subhadip</p>
              <p class="text-xs text-emerald-400">Online</p>
            </div>
            <div class="w-9 h-9 bg-gradient-to-br from-violet-500 to-fuchsia-500 rounded-2xl flex items-center justify-center text-white font-bold">S</div>
          </div>
        </div>
      </header>

      <!-- Dashboard Content -->
      <main class="flex-1 overflow-y-auto p-6 bg-zinc-950">
        <h2 class="text-3xl font-semibold mb-2">Good afternoon, Subhadip 👋</h2>
        <p class="text-zinc-400 mb-8">Here's what's happening with your platform today.</p>

        <!-- Metric Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="glass border border-zinc-700/50 rounded-3xl p-6 hover:border-violet-500/30 transition-all">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-400 text-sm">Total Revenue</p>
                <p class="text-4xl font-bold mt-2">$248,950</p>
              </div>
              <div class="w-12 h-12 bg-emerald-500/10 text-emerald-400 rounded-2xl flex items-center justify-center">
                <i class="fa-solid fa-dollar-sign text-2xl"></i>
              </div>
            </div>
            <p class="text-emerald-400 text-sm mt-4 flex items-center gap-1">
              <i class="fa-solid fa-arrow-trend-up"></i> +18.2% this month
            </p>
          </div>

          <div class="glass border border-zinc-700/50 rounded-3xl p-6 hover:border-violet-500/30 transition-all">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-400 text-sm">Active Users</p>
                <p class="text-4xl font-bold mt-2">12,459</p>
              </div>
              <div class="w-12 h-12 bg-blue-500/10 text-blue-400 rounded-2xl flex items-center justify-center">
                <i class="fa-solid fa-users text-2xl"></i>
              </div>
            </div>
            <p class="text-emerald-400 text-sm mt-4 flex items-center gap-1">
              <i class="fa-solid fa-arrow-trend-up"></i> +4.9% today
            </p>
          </div>

          <div class="glass border border-zinc-700/50 rounded-3xl p-6 hover:border-violet-500/30 transition-all">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-400 text-sm">Total Orders</p>
                <p class="text-4xl font-bold mt-2">3,284</p>
              </div>
              <div class="w-12 h-12 bg-amber-500/10 text-amber-400 rounded-2xl flex items-center justify-center">
                <i class="fa-solid fa-cart-shopping text-2xl"></i>
              </div>
            </div>
            <p class="text-rose-400 text-sm mt-4 flex items-center gap-1">
              <i class="fa-solid fa-arrow-trend-down"></i> -2.1% this week
            </p>
          </div>

          <div class="glass border border-zinc-700/50 rounded-3xl p-6 hover:border-violet-500/30 transition-all">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-400 text-sm">Conversion Rate</p>
                <p class="text-4xl font-bold mt-2">3.84%</p>
              </div>
              <div class="w-12 h-12 bg-violet-500/10 text-violet-400 rounded-2xl flex items-center justify-center">
                <i class="fa-solid fa-chart-pie text-2xl"></i>
              </div>
            </div>
            <p class="text-emerald-400 text-sm mt-4 flex items-center gap-1">
              <i class="fa-solid fa-arrow-trend-up"></i> +0.6% from last month
            </p>
          </div>
        </div>

        <!-- Charts & Activity -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
          <!-- Main Chart -->
          <div class="lg:col-span-2 glass border border-zinc-700/50 rounded-3xl p-6">
            <div class="flex justify-between mb-6">
              <h3 class="font-semibold">Revenue Overview</h3>
              <select class="bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-1 text-sm">
                <option>Last 30 days</option>
              </select>
            </div>
            <div class="h-80 bg-zinc-900/50 rounded-2xl flex items-center justify-center border border-dashed border-zinc-700">
              <p class="text-zinc-500 text-center">
                Chart goes here (use Chart.js or ApexCharts)<br>
                <span class="text-xs">Beautiful line/area chart with gradient fill</span>
              </p>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="glass border border-zinc-700/50 rounded-3xl p-6">
            <h3 class="font-semibold mb-6">Recent Activity</h3>
            <div class="space-y-6 text-sm">
              <div class="flex gap-4">
                <div class="w-2 h-2 mt-2 bg-emerald-400 rounded-full"></div>
                <div class="flex-1">
                  <p>New user registered: <span class="font-medium">Rahul Sharma</span></p>
                  <p class="text-xs text-zinc-500">2 minutes ago</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-2 h-2 mt-2 bg-violet-400 rounded-full"></div>
                <div class="flex-1">
                  <p>Order #3921 completed • $129.99</p>
                  <p class="text-xs text-zinc-500">18 minutes ago</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-2 h-2 mt-2 bg-amber-400 rounded-full"></div>
                <div class="flex-1">
                  <p>Server backup completed successfully</p>
                  <p class="text-xs text-zinc-500">1 hour ago</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      sidebar.classList.toggle('-translate-x-full');
    }

    // Tailwind script already included via CDN
  </script>
</body>
</html>