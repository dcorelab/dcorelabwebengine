<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dcore Lab • Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  
  <link rel="icon" href="/asset/core_lab__2_-removebg-preview.png" type="image/png">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: linear-gradient(145deg, #f1f5f9 0%, #c7d2fe 100%);
    }

    .glass {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.15);
      border: 1px solid rgba(255,255,255,0.6);
    }

    .stat-card {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .stat-card:hover {
      transform: translateY(-12px) scale(1.02);
      box-shadow: 0 30px 60px -15px rgb(99 102 241 / 0.3);
    }

    .tab {
      transition: all 0.3s ease;
    }
    
    .tab-active {
      background: linear-gradient(90deg, #6366f1, #8b5cf6);
      color: white;
      box-shadow: 0 10px 15px -3px rgb(99 102 241 / 0.4);
    }

    .logo-glow {
      filter: drop-shadow(0 0 15px rgb(99 102 241 / 0.5));
    }
  </style>
</head>
<body class="min-h-screen text-zinc-800">

  <!-- Premium Loading Screen -->
  <div id="loading-screen" class="fixed inset-0 bg-gradient-to-br from-slate-950 to-indigo-950 flex items-center justify-center z-[9999]">
    <div class="text-center">
      <img src="/asset/core_lab__2_-removebg-preview.png" 
           alt="Dcore Lab" 
           class="w-32 h-32 mx-auto logo-glow animate-pulse">
      <div class="mt-10 flex items-center justify-center gap-3">
        <div class="w-2 h-2 bg-white rounded-full animate-bounce"></div>
        <div class="w-2 h-2 bg-white rounded-full animate-bounce [animation-delay:150ms]"></div>
        <div class="w-2 h-2 bg-white rounded-full animate-bounce [animation-delay:300ms]"></div>
      </div>
      <p class="text-white/70 mt-8 text-sm font-medium tracking-widest">INITIALIZING DASHBOARD...</p>
    </div>
  </div>

  <div class="flex h-screen overflow-hidden">

    <!-- Enhanced Sidebar -->
    <div id="sidebar" class="w-72 bg-white/95 border-r border-zinc-200 flex flex-col shadow-2xl backdrop-blur-xl">
      <div class="p-8 border-b border-zinc-100">
        <div class="flex items-center gap-4">
          <img src="/asset/core_lab__2_-removebg-preview.png" style="height: 52px;" alt="Dcore Lab" class="logo-glow">
          <div>
            <h1 class="text-3xl font-bold tracking-tighter bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 bg-clip-text text-transparent">Dcore Lab</h1>
            <p class="text-xs text-zinc-500 -mt-1">Admin Portal</p>
          </div>
        </div>
      </div>

      <div class="flex-1 px-6 py-8 space-y-2 overflow-y-auto">
        <a href="#" class="flex items-center gap-4 px-6 py-4 rounded-3xl bg-gradient-to-r from-indigo-50 to-violet-50 text-indigo-700 font-semibold">
          <i class="fa-solid fa-house text-xl"></i>
          <span>Dashboard</span>
        </a>
        <a href="#" class="flex items-center gap-4 px-6 py-4 rounded-3xl text-zinc-600 hover:bg-zinc-100 transition-colors">
          <i class="fa-solid fa-users text-xl"></i>
          <span>Visitors</span>
        </a>
        <a href="#" class="flex items-center gap-4 px-6 py-4 rounded-3xl text-zinc-600 hover:bg-zinc-100 transition-colors">
          <i class="fa-solid fa-chart-pie text-xl"></i>
          <span>Analytics</span>
        </a>
      </div>

      <div class="p-6 border-t">
        <div class="flex items-center gap-4 p-4 bg-zinc-50 rounded-3xl">
          <div class="w-11 h-11 bg-gradient-to-br from-indigo-500 to-violet-500 rounded-2xl flex items-center justify-center text-white font-bold text-2xl shadow">S</div>
          <div class="flex-1">
            <p class="font-semibold">Subhadip</p>
            <p class="text-emerald-600 text-sm flex items-center gap-1">
              <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span> Online
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Area -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <header class="bg-white/90 backdrop-blur-xl border-b px-10 py-6 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <button onclick="toggleSidebar()" class="lg:hidden text-3xl text-zinc-500">
            <i class="fa-solid fa-bars"></i>
          </button>
          <h2 class="text-3xl font-semibold tracking-tight text-zinc-800">Analytics Overview</h2>
        </div>

        <div class="flex items-center gap-8">
         
          <div class="flex items-center gap-3">
            <div class="text-right">
              <p class="font-semibold text-zinc-800">Subhadip</p>
              <p class="text-xs text-zinc-500">Administrator</p>
            </div>
            <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-2xl flex items-center justify-center text-white font-bold shadow-inner">S</div>
          </div>
        </div>
      </header>

      <main class="flex-1 overflow-y-auto p-10">
        <div class="max-w-screen-2xl mx-auto">
          <!-- Welcome -->
          <div class="mb-12">
            <h1 class="text-6xl font-bold tracking-tighter text-zinc-900">Good afternoon, Subhadip 👋</h1>
            <p class="text-xl text-zinc-500 mt-3">Here's a real-time snapshot of your platform.</p>
          </div>

          <!-- Stat Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="glass stat-card rounded-3xl p-9">
              <div class="flex justify-between">
                <div>
                  <p class="uppercase text-xs tracking-widest text-zinc-500 font-medium">Total Views</p>
                  <p id="total-views" class="text-6xl font-bold mt-6 text-zinc-900">0</p>
                </div>
                <div class="text-5xl text-indigo-200">
                  <i class="fa-solid fa-eye"></i>
                </div>
              </div>
            </div>

            <div class="glass stat-card rounded-3xl p-9">
              <div class="flex justify-between">
                <div>
                  <p class="uppercase text-xs tracking-widest text-zinc-500 font-medium">Unique Visitors</p>
                  <p id="unique-visitors" class="text-6xl font-bold mt-6 text-violet-600">0</p>
                </div>
                <div class="text-5xl text-violet-200">
                  <i class="fa-solid fa-user-group"></i>
                </div>
              </div>
            </div>

            <div class="glass stat-card rounded-3xl p-9">
              <div class="flex justify-between">
                <div>
                  <p class="uppercase text-xs tracking-widest text-zinc-500 font-medium">Active Now</p>
                  <p id="active-now" class="text-6xl font-bold mt-6 text-emerald-600">0</p>
                </div>
                <div class="text-5xl text-emerald-200">
                  <i class="fa-solid fa-circle-dot"></i>
                </div>
              </div>
            </div>

            <div class="glass stat-card rounded-3xl p-9 flex items-center justify-center">
              <a href="https://vercel.com/dcorelab/dcorelabwebengine/analytics" target="_blank"
                 class="w-full text-center bg-gradient-to-r from-zinc-900 to-black hover:from-black hover:to-zinc-900 text-white py-5 rounded-3xl font-semibold text-lg transition-all flex items-center justify-center gap-3">
                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                Vercel Analytics
              </a>
            </div>
          </div>

          <!-- Chart Card with Tabs -->
          <div class="mt-12 glass rounded-3xl p-10">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-10">
              <div>
                <h3 class="text-3xl font-semibold tracking-tight">Home Page Views Trend</h3>
                <p class="text-zinc-500">Compare performance across different timeframes</p>
              </div>

              <!-- Time Tabs -->
              <div class="flex bg-white/70 backdrop-blur rounded-3xl p-1 shadow-inner">
                <button onclick="switchPeriod(0)" id="tab-0" class="tab tab-active px-8 py-3 rounded-3xl text-sm font-semibold">Today</button>
                <button onclick="switchPeriod(1)" id="tab-1" class="tab px-8 py-3 rounded-3xl text-sm font-semibold">7 Days</button>
                <button onclick="switchPeriod(2)" id="tab-2" class="tab px-8 py-3 rounded-3xl text-sm font-semibold">30 Days</button>
                <button onclick="switchPeriod(3)" id="tab-3" class="tab px-8 py-3 rounded-3xl text-sm font-semibold">All Time</button>
              </div>
            </div>

            <div class="bg-white rounded-2xl p-8 shadow-inner">
              <canvas id="viewsChart" height="140"></canvas>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    let chartInstance = null;
    let currentPeriod = 1;

    // Hide loading screen
    setTimeout(() => {
      const loader = document.getElementById('loading-screen');
      loader.style.transition = 'opacity 0.8s ease';
      loader.style.opacity = '0';
      setTimeout(() => loader.remove(), 800);
    }, 2000);

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
    }

    function updateTabs() {
      document.querySelectorAll('.tab').forEach((tab, i) => {
        tab.classList.toggle('tab-active', i === currentPeriod);
      });
    }

    async function loadLiveStats() {
      try {
        const res = await fetch('/api/vercel-realtime');
        const data = await res.json();

        document.getElementById('total-views').textContent = Number(data.homeHits || 0).toLocaleString();
        document.getElementById('unique-visitors').textContent = Number(data.uniqueVisitors || 0).toLocaleString();
        document.getElementById('active-now').textContent = Number(data.activeNow || 0);
      } catch (e) { console.error(e); }
    }

    async function loadChart(period) {
      currentPeriod = period;
      updateTabs();

      let query = period === 0 ? 'today' : period === 1 ? '7' : period === 2 ? '30' : 'total';

      try {
        const res = await fetch(`/api/analytics/chart?period=${query}`);
        const { labels, views } = await res.json();

        if (chartInstance) chartInstance.destroy();

        chartInstance = new Chart(document.getElementById('viewsChart'), {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Page Views',
              data: views,
              borderColor: '#6366f1',
              backgroundColor: 'rgba(99, 102, 241, 0.08)',
              borderWidth: 5,
              tension: 0.4,
              pointRadius: 6,
              pointHoverRadius: 9,
              pointBackgroundColor: '#ffffff',
              pointBorderWidth: 3
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: '#e2e8f0' }, ticks: { color: '#64748b' } },
              x: { grid: { color: '#e2e8f0' }, ticks: { color: '#64748b' } }
            }
          }
        });
      } catch (e) { console.error(e); }
    }

    function switchPeriod(p) {
      loadChart(p);
    }

    // Init
    window.onload = () => {
      loadLiveStats();
      loadChart(1);                    // Start with 7 Days
      setInterval(loadLiveStats, 8000); // Refresh stats faster
    };
  </script>
</body>
</html>