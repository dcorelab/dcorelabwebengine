<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dcore Lab • Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"/>
  
  <link rel="icon" href="/asset/core_lab__2_-removebg-preview.png" type="image/png">
  
  <script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://apis.google.com/js/api.js"></script>

  <style>
    body { font-family: 'Inter', system-ui, sans-serif; background: #f8fafc; }
    .glass { background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05); }
    .sidebar { transition: all 0.3s ease; }
    .particle-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
    .logo-gradient { background: linear-gradient(90deg, #000000, #000000); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ga-chart { height: 320px; }
  </style>
</head>
<body class="min-h-screen text-zinc-800">

  <div id="tsparticles" class="particle-bg"></div>

  <div class="flex h-screen overflow-hidden">

    <!-- Sidebar (same as before) -->
    <div id="sidebar" class="sidebar w-64 bg-white border-r border-zinc-200 flex flex-col shadow-xl">
      <div class="p-6 border-b border-zinc-100">
        <h1 class="text-3xl font-bold tracking-tight flex items-center gap-3">
          <img src="/asset/core_lab__2_-removebg-preview.png" style="height: 40px;" alt="Dcore Lab">
          <span class="logo-gradient">Dcore Lab</span>
        </h1>
      </div>
      <div class="flex-1 overflow-y-auto p-4">
        <nav class="space-y-1">
          <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm font-medium bg-violet-50 text-violet-700 rounded-2xl">
            <i class="fa-solid fa-gauge-high"></i> Dashboard
          </a>
          <!-- other nav links same -->
        </nav>
      </div>
      <div class="p-4 border-t border-zinc-100">
        <div class="flex items-center gap-3 px-4 py-3 bg-zinc-50 rounded-2xl">
          <div class="w-10 h-10 bg-zinc-200 rounded-full flex items-center justify-center text-2xl">👨‍💼</div>
          <div>
            <p class="font-medium text-zinc-800">Subhadip</p>
            <p class="text-xs text-zinc-500">Admin</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <header class="bg-white border-b border-zinc-200 px-6 py-4 flex items-center justify-between shadow-sm">
        <!-- Top navbar same as before -->
        <div class="flex items-center gap-4">
          <button onclick="toggleSidebar()" class="lg:hidden text-2xl text-zinc-600"><i class="fa-solid fa-bars"></i></button>
          <div class="relative w-80">
            <input type="text" placeholder="Search anything..." class="w-full bg-zinc-100 border border-zinc-200 focus:border-violet-400 rounded-2xl py-3 px-5 pl-12 outline-none text-sm"/>
            <i class="fa-solid fa-magnifying-glass absolute left-5 top-3.5 text-zinc-400"></i>
          </div>
        </div>
        <div class="flex items-center gap-6">
          <button class="relative hover:scale-110 transition-transform"><i class="fa-solid fa-bell text-xl text-zinc-600"></i><span class="absolute -top-1 -right-1 w-5 h-5 bg-rose-500 text-white text-xs rounded-full flex items-center justify-center">3</span></button>
          <button class="hover:scale-110 transition-transform text-zinc-600"><i class="fa-solid fa-sun text-xl"></i></button>
          <div class="flex items-center gap-3">
            <div class="text-right">
              <p class="text-sm font-medium">Subhadip</p>
              <p class="text-xs text-emerald-600">Online</p>
            </div>
            <div class="w-9 h-9 bg-gradient-to-br from-violet-500 to-fuchsia-500 rounded-2xl flex items-center justify-center text-white font-bold shadow">S</div>
          </div>
        </div>
      </header>

      <main class="flex-1 overflow-y-auto p-8">
        <h2 class="text-4xl font-semibold mb-2">Good afternoon, Subhadip 👋</h2>
        <p class="text-zinc-500 mb-10">Here's what's happening with your platform today.</p>

        <!-- Metric Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Revenue, Total Users, Orders, Conversion same as before -->
          <div class="glass border border-zinc-100 rounded-3xl p-6">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-500 text-sm">Total Revenue</p>
                <p class="text-4xl font-bold mt-2 text-zinc-800">$248,950</p>
              </div>
              <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center"><i class="fa-solid fa-dollar-sign text-2xl"></i></div>
            </div>
          </div>

          <div class="glass border border-zinc-100 rounded-3xl p-6">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-500 text-sm">Total Users (30d)</p>
                <p id="total-users" class="text-4xl font-bold mt-2 text-zinc-800">—</p>
              </div>
              <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center"><i class="fa-solid fa-users text-2xl"></i></div>
            </div>
          </div>

          <!-- New: Search Console Cards -->
          <div class="glass border border-zinc-100 rounded-3xl p-6">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-500 text-sm">Search Clicks (30d)</p>
                <p id="search-clicks" class="text-4xl font-bold mt-2 text-amber-600">—</p>
              </div>
              <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-2xl flex items-center justify-center"><i class="fa-solid fa-mouse-pointer text-2xl"></i></div>
            </div>
          </div>

          <div class="glass border border-zinc-100 rounded-3xl p-6">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-zinc-500 text-sm">Search Impressions (30d)</p>
                <p id="search-impressions" class="text-4xl font-bold mt-2 text-violet-600">—</p>
              </div>
              <div class="w-12 h-12 bg-violet-100 text-violet-600 rounded-2xl flex items-center justify-center"><i class="fa-solid fa-eye text-2xl"></i></div>
            </div>
          </div>
        </div>

        <!-- Analytics Section -->
        <div class="mt-12">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-semibold text-zinc-800">Analytics Overview</h3>
            <button onclick="connectGoogleAnalytics()" class="text-violet-600 hover:text-violet-700 flex items-center gap-2 text-sm font-medium">
              <i class="fa-solid fa-plug"></i> Connect Google Analytics + Search Console
            </button>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Real-time Visitors (GA4) -->
            <div class="glass border border-zinc-100 rounded-3xl p-6">
              <h4 class="font-medium mb-4 flex items-center gap-2"><i class="fa-solid fa-users text-emerald-600"></i> Real-time Visitors</h4>
              <div id="realtime-visitors" class="text-6xl font-bold text-emerald-600 mb-2">—</div>
              <p class="text-zinc-500 text-sm">Users currently on your site</p>
              <button onclick="refreshRealtime()" class="mt-4 text-xs text-violet-600 hover:underline"><i class="fa-solid fa-rotate"></i> Refresh</button>
            </div>

            <!-- Sessions Chart -->
            <div class="glass border border-zinc-100 rounded-3xl p-6">
              <h4 class="font-medium mb-4">Sessions (Last 30 Days)</h4>
              <div class="ga-chart bg-white rounded-2xl border border-zinc-100 p-4">
                <canvas id="sessionsChart"></canvas>
              </div>
            </div>
          </div>

          <!-- Looker Studio iframe (optional) -->
          <div class="mt-8 glass border border-zinc-100 rounded-3xl p-6">
            <h4 class="font-medium mb-6">Full Traffic Overview</h4>
            <div class="bg-white rounded-2xl border border-zinc-100 overflow-hidden" style="height: 520px;">
              <iframe src="https://lookerstudio.google.com/embed/reporting/YOUR_REPORT_ID" width="100%" height="100%" frameborder="0" allowfullscreen></iframe>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    // ================== CONFIGURATION ==================
    const CLIENT_ID = 'YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com';   // ← Replace
    const GA_PROPERTY_ID = 'YOUR_GA4_PROPERTY_ID';                        // ← Replace (number)
    const GSC_SITE_URL = 'https://dcorelab.com/';                      // ← Replace with exact site URL from Search Console (or sc-domain:yourdomain.com)
    // ===================================================

    let tokenClient;
    let gapiInited = false;
    let chartInstance = null;

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
    }

    // tsParticles
    tsParticles.load("tsparticles", {
      background: { color: { value: "transparent" } },
      fpsLimit: 60,
      particles: {
        color: { value: ["#6d28d9", "#c026d3", "#a5b4fc"] },
        links: { enable: true, color: "#e0e7ff", distance: 150, opacity: 0.15 },
        move: { enable: true, speed: 1.5 },
        number: { value: 80 },
        opacity: { value: 0.4, random: true },
        shape: { type: "circle" },
        size: { value: { min: 1, max: 4 } }
      },
      interactivity: { events: { onHover: { enable: true, mode: "repulse" } } },
      detectRetina: true
    });

    function initGapi() {
      gapi.load('client', async () => {
        await gapi.client.init({
          clientId: CLIENT_ID,
          discoveryDocs: [
            'https://analyticsdata.googleapis.com/$discovery/rest?version=v1beta',
            'https://searchconsole.googleapis.com/$discovery/rest?version=v1'
          ],
          scope: 'https://www.googleapis.com/auth/analytics.readonly https://www.googleapis.com/auth/webmasters.readonly'
        });
        gapiInited = true;
      });
    }

    function initTokenClient() {
      tokenClient = google.accounts.oauth2.initTokenClient({
        client_id: CLIENT_ID,
        scope: 'https://www.googleapis.com/auth/analytics.readonly https://www.googleapis.com/auth/webmasters.readonly',
        callback: (resp) => {
          if (resp.error) return console.error(resp);
          loadAllData();
        }
      });
    }

    window.connectGoogleAnalytics = function() {
      if (!gapiInited) return alert("Please wait a moment and try again.");
      tokenClient.requestAccessToken({ prompt: '' });
    };

    async function loadAllData() {
      if (!gapi.client.getToken()) return;

      // GA4 Real-time + Total Users + Sessions Chart (same as before)
      await loadGA4Data();

      // Search Console Data
      await loadSearchConsoleData();
    }

    // GA4 functions (real-time, total users, sessions chart) - same as previous version
    async function loadGA4Data() {
      // ... (copy the GA4 code from previous full version: realtime, total-users, sessionsChart)
      // For brevity, I'm keeping only new parts here. Add the previous GA4 code if needed.
    }

    async function loadSearchConsoleData() {
      try {
        const res = await gapi.client.request({
          path: `https://searchconsole.googleapis.com/webmasters/v3/sites/${encodeURIComponent(GSC_SITE_URL)}/searchAnalytics/query`,
          method: 'POST',
          body: {
            startDate: "2026-03-13",   // 30 days ago (adjust if needed)
            endDate: "2026-04-12",
            dimensions: ["query"],
            rowLimit: 1   // we only need aggregate totals
          }
        });

        const row = res.result.rows ? res.result.rows[0] : null;
        const clicks = row ? row.clicks : 0;
        const impressions = row ? row.impressions : 0;
        const ctr = row && impressions > 0 ? (row.ctr * 100).toFixed(2) : 0;
        const position = row ? row.position.toFixed(1) : 0;

        document.getElementById('search-clicks').textContent = parseInt(clicks).toLocaleString();
        document.getElementById('search-impressions').textContent = parseInt(impressions).toLocaleString();

        // Optional: You can add more cards for CTR and Position if you want
        console.log(`GSC → Clicks: ${clicks}, Impressions: ${impressions}, CTR: ${ctr}%, Avg Position: ${position}`);
      } catch (e) {
        console.error("Search Console Error:", e);
        document.getElementById('search-clicks').textContent = "Error";
        document.getElementById('search-impressions').textContent = "Error";
      }
    }

    // Real-time refresh (GA4)
    async function refreshRealtime() {
      // Add your realtime GA4 code here
      console.log("Refreshing real-time visitors...");
    }

    window.onload = () => {
      initGapi();
      initTokenClient();

      // Demo values
      setTimeout(() => {
        if (document.getElementById('realtime-visitors')) document.getElementById('realtime-visitors').textContent = '142';
      }, 1500);
    };
  </script>
</body>
</html>