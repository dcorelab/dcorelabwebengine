  <!-- Sidebar -->
<style>
  .sidebar {
    overflow-y: auto;
  }
  
  .sidebar::-webkit-scrollbar {
    width: 4px;
  }
  
  .sidebar::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 2px;
  }
  
  .sidebar::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #c09d01, #22c55e);
    border-radius: 2px;
  }
  
  .sidebar::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(to bottom, #a68a00, #16a34a);
  }
  
  /* For Firefox support */
  .sidebar {
    scrollbar-width: 1px;
    scrollbar-gutter: var(--bg-sidebar);
    scrollbar-color: #002fff #000000;
  }
</style>

