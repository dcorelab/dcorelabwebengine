    <script>
        // ── ANIMATED DOTTED BACKGROUND ──
        const bgContainer = document.getElementById('animated-bg');
        const dotCount = 80;
        const lineCount = 15;

        // Create animated dots
        for (let i = 0; i < dotCount; i++) {
            const dot = document.createElement('div');
            dot.className = 'dot';
            
            const colorClasses = ['blue', 'purple', 'pink', 'cyan'];
            dot.classList.add(colorClasses[Math.floor(Math.random() * colorClasses.length)]);
            
            dot.style.left = Math.random() * 100 + '%';
            dot.style.top = Math.random() * 100 + '%';
            dot.style.animationDelay = Math.random() * 20 + 's';
            dot.style.animationDuration = (15 + Math.random() * 20) + 's';
            
            bgContainer.appendChild(dot);
        }

        // Create animated lines
        for (let i = 0; i < lineCount; i++) {
            const line = document.createElement('div');
            line.className = 'line-connector';
            
            const x = Math.random() * 100;
            const y = Math.random() * 100;
            const width = 100 + Math.random() * 200;
            const height = 1 + Math.random() * 2;
            const rotation = Math.random() * 360;
            
            line.style.left = x + '%';
            line.style.top = y + '%';
            line.style.width = width + 'px';
            line.style.height = height + 'px';
            line.style.transform = `rotate(${rotation}deg)`;
            line.style.animationDelay = Math.random() * 15 + 's';
            line.style.animationDuration = (12 + Math.random() * 18) + 's';
            
            bgContainer.appendChild(line);
        }

        // Navigation scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // Fade in on scroll
        const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -100px 0px' };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

        console.log('%c✨ Dcore Lab Premium Website Loaded!', 'color:#3B82F6; font-size:18px; font-weight:bold;');
        console.log('%c🎨 Light Theme | Animated Dotted Background | Beautiful Modern Design', 'color:#8B5CF6; font-size:14px; font-weight:bold;');
    </script>
