    <style>
        :root {
            --primary-light: #F8FAFC;
            --secondary-light: #F1F5F9;
            --tertiary-light: #E2E8F0;
            --accent-blue: #3B82F6;
            --accent-purple: #8B5CF6;
            --accent-pink: #EC4899;
            --accent-cyan: #06B6D4;
            --accent-emerald: #10B981;
            --accent-amber: #F59E0B;
            --text-dark: #1E293B;
            --text-light: #475569;
            --text-lighter: #64748B;
            --border-light: #E2E8F0;
            --shadow: 0 10px 35px rgba(59, 130, 246, 0.15);
            --shadow-lg: 0 20px 50px rgba(59, 130, 246, 0.2);
            --shadow-glow: 0 0 40px rgba(139, 92, 246, 0.25);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: linear-gradient(135deg, var(--primary-light) 0%, #FFFFFF 50%, #F0F9FF 100%);
            
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            line-height: 1.6;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            position: relative;
        }

        a {
            color: inherit;
            text-decoration: none;
            transition: all 0.3s;
        }

        img {
            max-width: 100%;
            height: auto;
        }

        /* ── ANIMATED DOTTED BACKGROUND ── */
        #animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            background: linear-gradient(135deg, var(--primary-light) 0%, #FFFFFF 50%, #F0F9FF 100%);
        }

        .dot {
            position: absolute;
            width: 3px;
            height: 3px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.6), rgba(139, 92, 246, 0.3));
            border-radius: 50%;
            animation: float 20s infinite ease-in-out;
        }

        .dot.blue {
            background: radial-gradient(circle, rgba(59, 130, 246, 0.7), rgba(59, 130, 246, 0.2));
        }

        .dot.purple {
            background: radial-gradient(circle, rgba(139, 92, 246, 0.7), rgba(139, 92, 246, 0.2));
        }

        .dot.pink {
            background: radial-gradient(circle, rgba(236, 72, 153, 0.6), rgba(236, 72, 153, 0.2));
        }

        .dot.cyan {
            background: radial-gradient(circle, rgba(6, 182, 212, 0.6), rgba(6, 182, 212, 0.2));
        }

        @keyframes float {
            0% {
                transform: translateY(0px) translateX(0px);
                opacity: 0.3;
            }
            25% {
                opacity: 0.8;
            }
            50% {
                transform: translateY(-50px) translateX(30px);
                opacity: 1;
            }
            75% {
                opacity: 0.6;
            }
            100% {
                transform: translateY(0px) translateX(0px);
                opacity: 0.3;
            }
        }

        .line-connector {
            position: absolute;
            background: linear-gradient(90deg, rgba(59, 130, 246, 0.4), rgba(139, 92, 246, 0.2), transparent);
            animation: drawLine 15s infinite ease-in-out;
        }

        @keyframes drawLine {
            0% {
                opacity: 0.2;
                transform: scaleX(0);
            }
            50% {
                opacity: 0.8;
                transform: scaleX(1);
            }
            100% {
                opacity: 0.2;
                transform: scaleX(1);
            }
        }

        /* ── NAVIGATION ── */
        nav.navbar {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            border-bottom: 2px solid var(--border-light);
            transition: all 0.3s;
            position: relative;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.08);
        }

        nav.navbar.scrolled {
            box-shadow: var(--shadow-lg);
            background: rgba(255, 255, 255, 0.98);
        }

        .navbar-brand {
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-brand:hover {
            transform: scale(1.05);
            filter: drop-shadow(0 0 10px rgba(139, 92, 246, 0.4));
        }

        .navbar-brand i {
            font-size: 2rem;
        }

        .nav-link {
            font-size: 0.95rem;
            color: var(--text-light);
            font-weight: 600;
            transition: all 0.3s;
            position: relative;
            margin: 0 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
            transition: width 0.3s;
            border-radius: 3px;
        }

        .nav-link:hover {
            color: var(--accent-blue);
            transform: translateY(-2px);
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .nav-cta {
            padding: 10px 28px !important;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white !important;
            border-radius: 25px;
            font-weight: 700;
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            border: none;
        }

        .nav-cta:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(59, 130, 246, 0.5);
        }

        /* ── HERO SECTION ── */
        #hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 100px 5vw 50px;
            overflow: hidden;
            z-index: 2;
        }

        .hero-content {
            position: relative;
            z-index: 3;
            max-width: 1100px;
            margin: 0 auto;
            text-align: center;
            padding: 60px 0;
        }

        .hero-label {
            display: inline-block;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--accent-blue);
            background: rgba(59, 130, 246, 0.1);
            border: 2px solid var(--accent-blue);
            padding: 12px 24px;
            border-radius: 50px;
            margin-bottom: 2rem;
            animation: slideUp 0.8s ease-out;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .hero-headline {
            font-family: 'Poppins', sans-serif;
            font-size: clamp(2.5rem, 8vw, 5.5rem);
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin-bottom: 1.5rem;
            color: var(--text-dark);
            animation: slideUp 0.8s ease-out 0.1s backwards;
        }

        .hero-headline .accent {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientFlow 4s ease infinite;
        }

        @keyframes gradientFlow {
            0% { filter: hue-rotate(0deg) brightness(1); }
            50% { filter: hue-rotate(15deg) brightness(1.1); }
            100% { filter: hue-rotate(0deg) brightness(1); }
        }

        .hero-sub {
            font-size: 1.15rem;
            color: var(--text-light);
            max-width: 700px;
            margin: 0 auto 2.5rem;
            line-height: 1.9;
            animation: slideUp 0.8s ease-out 0.2s backwards;
            font-weight: 500;
        }

        .hero-actions {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
            animation: slideUp 0.8s ease-out 0.3s backwards;
        }

        .btn {
            padding: 16px 40px;
            font-size: 1rem;
            font-weight: 700;
            border-radius: 50px;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            font-family: 'Poppins', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);
        }

        .btn-primary:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(59, 130, 246, 0.6);
        }

        .btn-secondary {
            background: white;
            color: var(--accent-blue);
            border: 3px solid var(--accent-blue);
            box-shadow: 0 5px 20px rgba(59, 130, 246, 0.15);
        }

        .btn-secondary:hover {
            background: rgba(59, 130, 246, 0.05);
            transform: translateY(-4px);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-metrics {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            margin-top: 5rem;
            padding-top: 3rem;
            border-top: 3px solid var(--border-light);
            animation: slideUp 0.8s ease-out 0.4s backwards;
        }

        .metric {
            text-align: center;
            padding: 2rem 1.5rem;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(139, 92, 246, 0.08));
            border-radius: 20px;
            border: 2px solid rgba(59, 130, 246, 0.15);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .metric::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.2), transparent);
            border-radius: 50%;
            animation: float 8s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) translateX(0px); }
            50% { transform: translateY(-30px) translateX(-30px); }
        }

        .metric:hover {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(139, 92, 246, 0.15));
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
        }

        .metric-val {
            font-family: 'Poppins', sans-serif;
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            position: relative;
            z-index: 2;
        }

        .metric-label {
            font-size: 0.85rem;
            color: var(--text-light);
            margin-top: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 700;
            position: relative;
            z-index: 2;
        }

        /* ── SECTIONS ── */
        section {
            position: relative;
            padding: 120px 5vw;
            z-index: 2;
        }

        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--accent-purple);
            background: rgba(139, 92, 246, 0.1);
            padding: 10px 20px;
            border-radius: 50px;
            margin-bottom: 1.5rem;
            letter-spacing: 0.1em;
            border: 2px solid rgba(139, 92, 246, 0.3);
            text-transform: uppercase;
        }

        .section-title {
            font-family: 'Poppins', sans-serif;
            font-size: clamp(2rem, 5vw, 3.8rem);
            font-weight: 900;
            line-height: 1.2;
            letter-spacing: -0.02em;
            margin-bottom: 1rem;
            color: var(--text-dark);
        }

        .section-title .gradient-text {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .section-sub {
            font-size: 1rem;
            color: var(--text-light);
            max-width: 700px;
            line-height: 1.8;
            margin-bottom: 3rem;
            font-weight: 500;
        }

        .fade-in {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: none;
        }

        /* ── SAAS SOLUTIONS ── */
        #saas {
            background: linear-gradient(180deg, rgba(59, 130, 246, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
            border-bottom: 3px solid var(--border-light);
        }

        .saas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .saas-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(240, 249, 255, 0.9));
            border: 3px solid var(--border-light);
            border-radius: 20px;
            padding: 2.5rem;
            transition: all 0.4s;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05);
        }

        .saas-card::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -40%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15), transparent);
            border-radius: 50%;
            animation: orbitCircle 8s linear infinite;
        }

        @keyframes orbitCircle {
            0% { transform: rotate(0deg) translateX(50px) rotate(0deg); }
            100% { transform: rotate(360deg) translateX(50px) rotate(-360deg); }
        }

        .saas-card-content {
            position: relative;
            z-index: 2;
        }

        .saas-card:hover {
            transform: translateY(-15px) scale(1.02);
            border-color: var(--accent-blue);
            box-shadow: var(--shadow-lg);
            background: linear-gradient(135deg, #FFFFFF 0%, rgba(230, 245, 255, 0.9) 100%);
        }

        .saas-icon {
            font-size: 3rem;
            margin-bottom: 1.5rem;
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-cyan));
            border-radius: 50%;
            color: white;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
        }

        .saas-card h3 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            color: var(--text-dark);
        }

        .saas-card p {
            color: var(--text-light);
            line-height: 1.8;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        .saas-features {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .saas-features li {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-light);
            font-size: 0.95rem;
            font-weight: 500;
        }

        .saas-features li::before {
            content: '\f058';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            color: var(--accent-emerald);
            font-size: 1.2rem;
        }

        /* ── DIGITAL MARKETING ── */
        #digital-marketing {
            background: linear-gradient(180deg, rgba(236, 72, 153, 0.04) 0%, rgba(139, 92, 246, 0.04) 100%);
            border-bottom: 3px solid var(--border-light);
        }

        .marketing-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: center;
            max-width: 1300px;
            margin: 0 auto;
        }

        .marketing-text h3 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: var(--text-dark);
        }

        .marketing-text p {
            color: var(--text-light);
            line-height: 1.9;
            margin-bottom: 2rem;
            font-size: 1rem;
            font-weight: 500;
        }

        .marketing-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .marketing-item {
            padding: 2rem;
            background: linear-gradient(135deg, rgba(236, 72, 153, 0.08), rgba(236, 72, 153, 0.04));
            border-radius: 16px;
            border: 2px solid rgba(236, 72, 153, 0.15);
            transition: all 0.3s;
            position: relative;
        }

        .marketing-item::before {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -50%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(236, 72, 153, 0.1), transparent);
            border-radius: 50%;
        }

        .marketing-item:hover {
            background: linear-gradient(135deg, rgba(236, 72, 153, 0.15), rgba(236, 72, 153, 0.08));
            transform: translateY(-8px);
            border-color: var(--accent-pink);
        }

        .marketing-item h4 {
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            margin-bottom: 0.75rem;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.1rem;
            position: relative;
            z-index: 2;
        }

        .marketing-item p {
            font-size: 0.95rem;
            color: var(--text-light);
            margin: 0;
            position: relative;
            z-index: 2;
        }

        .marketing-visual {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(236, 72, 153, 0.08));
            border: 3px solid var(--border-light);
            border-radius: 20px;
            padding: 2rem;
            min-height: 450px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .marketing-visual::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15), transparent);
            border-radius: 50%;
